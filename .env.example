# Copy to `.env` and adjust to your machine. Values here override the study
# defaults in settings.py. Loaded automatically at import time via python-dotenv.
# Plain shell environment variables of the same name work too (and take precedence
# only if you don't set them in .env).

# Root of the external data drive (defaults to /Volumes/My_Book).
RC_DRIVE=/Volumes/My_Book

# Parcelled input data directory (defaults to <RC_DRIVE>/parcelled_data_niv).
RC_DATA_DIR=/Volumes/My_Book/parcelled_data_niv

# Directory where analysis results are written
# (defaults to <RC_DRIVE>/fmri-relational-coding-results).
RC_RESULTS_DIR=/Volumes/My_Book/fmri-relational-coding-results
